{
    "name": "essabu/essabu",
    "description": "Official Essabu PHP SDK - Unified client for all Essabu APIs (HR, Accounting, Identity, Trade, Payment, E-Invoice, Project, Asset)",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "essabu",
        "sdk",
        "api",
        "hr",
        "accounting",
        "identity",
        "trade",
        "payment",
        "einvoice",
        "project",
        "asset",
        "erp",
        "saas",
        "billing",
        "payroll",
        "crm",
        "inventory"
    ],
    "homepage": "https://github.com/essabu/essabu-php",
    "authors": [
        {
            "name": "Essabu",
            "email": "sdk@essabu.com",
            "homepage": "https://essabu.com"
        }
    ],
    "support": {
        "issues": "https://github.com/essabu/essabu-php/issues",
        "source": "https://github.com/essabu/essabu-php",
        "docs": "https://docs.essabu.com",
        "email": "support@essabu.com"
    },
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5|^11.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Essabu\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Essabu\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-text --coverage-html=coverage",
        "analyse": "phpstan analyse src --level=5",
        "cs-fix": "php-cs-fixer fix --diff",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "ci": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
