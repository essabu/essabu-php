{
    "name": "essabu/essabu",
    "description": "Official PHP SDK for the Essabu platform - unified access to HR, Accounting, Identity, Trade, Payment, E-Invoice, Project, and Asset modules.",
    "type": "library",
    "license": "MIT",
    "keywords": ["essabu", "sdk", "api", "hr", "accounting", "billing", "saas"],
    "homepage": "https://github.com/essabu/essabu-php",
    "authors": [
        {
            "name": "Essabu Team",
            "email": "dev@essabu.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.8",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Essabu\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Essabu\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    }
}
